{
  "name": "echo-cave",
  "version": "1.0.0",
  "description": "An audio-first cave exploration game designed for blind and sighted players.",
  "main": "index.html",
  "scripts": {
    "serve": "python3 -m http.server 8080",
    "build": "node scripts/build-web.mjs",
    "build:ios": "ECHO_TRANSCODE_AUDIO=1 node scripts/build-web.mjs",
    "ios:add": "npm run build:ios && npx cap add ios --packagemanager SPM",
    "ios:sync": "npm run build:ios && npx cap sync ios",
    "ios:open": "npx cap open ios",
    "test": "python3 tests/run_tests.py",
    "test:all": "python3 tests/run_tests.py --all",
    "test:browsers": "python3 tests/run_tests.py --browsers chromium,webkit",
    "test:static": "python3 tests/run_tests.py --static-only"
  },
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "keywords": [
    "audio",
    "accessibility",
    "blind",
    "low-vision",
    "screen-reader",
    "single-page",
    "game"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@capacitor/app": "8.1.1",
    "@capacitor/core": "8.4.2",
    "@capacitor/haptics": "8.0.2",
    "@capacitor/ios": "8.4.2",
    "@capacitor/preferences": "8.0.1",
    "@capacitor/screen-reader": "8.0.1",
    "@capacitor/share": "8.0.1"
  },
  "devDependencies": {
    "@capacitor/cli": "8.4.2"
  }
}
